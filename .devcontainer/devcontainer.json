{
  "name": "BingehOS CMMS",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/dotnet:1": {
      "version": "8.0"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [3000, 8080, 8081, 9000, 9001, 15672],
  "portsAttributes": {
    "3000": { "label": "Web UI", "onAutoForward": "notify" },
    "8080": { "label": "API HTTP", "onAutoForward": "silent" },
    "8081": { "label": "API HTTPS", "onAutoForward": "silent" },
    "9000": { "label": "MinIO S3", "onAutoForward": "silent" },
    "9001": { "label": "MinIO Console", "onAutoForward": "silent" },
    "15672": { "label": "RabbitMQ", "onAutoForward": "silent" }
  },
  "postCreateCommand": "cd web && npm install && echo 'NEXT_PUBLIC_API_URL=http://localhost:8080' > .env.local",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
